FROM rust:1.77-alpine AS builder

WORKDIR /app
RUN apk add --no-cache musl-dev gcc make pkgconfig openssl-dev

# Copy workspace
COPY . .
RUN cargo build --release --bin ivy-server

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /app/target/release/ivy-server /usr/local/bin/
EXPOSE 3001
CMD ["ivy-server"]
