# ============================================
# 🌿 Ivy — Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
RUST_LOG=ivy=debug,tower_http=debug

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://ivy:ivy_secret@localhost:5432/ivy
DATABASE_MAX_CONNECTIONS=10

# ---- Graph Database (Neo4j) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ivy_neo4j_secret

# ---- Cache (Redis) ----
REDIS_URL=redis://localhost:6379

# ---- JWT Auth ----
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24

# ---- Encryption Key (for API key storage) ----
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# ---- LLM Provider (choose one as default) ----
# Options: gemini, claude, openai, ollama
DEFAULT_LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Anthropic Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (local)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- Docker ----
DOCKER_SOCKET=/var/run/docker.sock
TOOL_CONTAINER_MEMORY_LIMIT=2g
TOOL_CONTAINER_CPU_LIMIT=1.0
TOOL_DEFAULT_TIMEOUT_SECS=300

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
